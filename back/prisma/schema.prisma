generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODÈLES (TABLES) ---

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String
  password       String
  xp             Int      @default(0)
  completedHunts Int      @default(0)
  role           String   @default("PLAYER")
  createdAt      DateTime @default(now())

  // Relations
  huntsCreated Hunt[]
}

model Hunt {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  difficulty  Int      @default(1)
  city        String?
  createdAt   DateTime @default(now())

  // Les coordonnées précises du point de départ !
  startLat Float?
  startLng Float?

  // Relations
  creatorId Int
  creator   User   @relation(fields: [creatorId], references: [id])
  steps     Step[]
}

model Step {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  latitude    Float
  longitude   Float
  order       Int

  // Relations
  huntId Int
  hunt   Hunt @relation(fields: [huntId], references: [id], onDelete: Cascade)
}
